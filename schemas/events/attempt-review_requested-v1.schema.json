{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/EduGoGroup/edugo-infrastructure/schemas/events/attempt-review-requested-v1",
  "title": "Attempt Review Requested Event",
  "description": "Evento publicado cuando un intento entregado queda pendiente de revisión (open_ended sin calificar o short_answer con fuzzy-fail)",
  "type": "object",
  "required": ["event_id", "event_type", "event_version", "timestamp", "payload"],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "ID único del evento (UUID)"
    },
    "event_type": {
      "type": "string",
      "const": "attempt.review_requested",
      "description": "Tipo de evento"
    },
    "event_version": {
      "type": "string",
      "const": "1.0",
      "description": "Versión del schema"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp ISO 8601 del evento"
    },
    "payload": {
      "type": "object",
      "required": ["attempt_id", "assessment_id", "school_id", "answers"],
      "properties": {
        "attempt_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID del intento en PostgreSQL"
        },
        "assessment_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID de la evaluación del intento"
        },
        "school_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID de la escuela"
        },
        "answers": {
          "type": "array",
          "minItems": 1,
          "description": "Respuestas que requieren revisión",
          "items": {
            "type": "object",
            "required": ["answer_id", "question_type"],
            "properties": {
              "answer_id": {
                "type": "string",
                "format": "uuid",
                "description": "ID de la respuesta (assessment_attempt_answer)"
              },
              "question_type": {
                "type": "string",
                "enum": ["open_ended", "short_answer"],
                "description": "Tipo de pregunta que define el carril de revisión"
              }
            }
          }
        }
      }
    }
  },
  "additionalProperties": false
}
