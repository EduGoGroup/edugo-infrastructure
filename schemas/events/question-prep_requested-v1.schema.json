{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/EduGoGroup/edugo-infrastructure/schemas/events/question-prep-requested-v1",
  "title": "Question Prep Requested Event",
  "description": "Evento publicado cuando una pregunta necesita (re)generar su artefacto de preparación para el LLM (plan 042: creación, edición, comentario del profesor o backfill)",
  "type": "object",
  "required": ["event_id", "event_type", "event_version", "timestamp", "payload"],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "ID único del evento (UUID)"
    },
    "event_type": {
      "type": "string",
      "const": "question.prep_requested",
      "description": "Tipo de evento"
    },
    "event_version": {
      "type": "string",
      "const": "1.0",
      "description": "Versión del schema"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp ISO 8601 del evento"
    },
    "payload": {
      "type": "object",
      "required": ["question_id", "assessment_id", "reason"],
      "properties": {
        "question_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID de la pregunta en PostgreSQL"
        },
        "assessment_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID de la evaluación a la que pertenece la pregunta"
        },
        "reason": {
          "type": "string",
          "enum": ["created", "updated", "feedback", "backfill"],
          "description": "Motivo que disparó la preparación (creación, edición, comentario del profesor o backfill)"
        }
      }
    }
  },
  "additionalProperties": false
}
